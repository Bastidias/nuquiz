{
  "name": "nuquiz",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @nuquiz/api dev & pnpm --filter @nuquiz/web dev",
    "build": "pnpm -r build",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "db:generate": "pnpm --filter @nuquiz/api db:generate",
    "db:migrate": "pnpm --filter @nuquiz/api db:migrate"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6"
  }
}
